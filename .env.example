# =============================================================================
# EV Diagnostic — variabili ambiente (web + Vercel + allineamento ESP32)
# Copia in web/.env.local per sviluppo; su Vercel: Project → Settings → Environment Variables.
# =============================================================================

# --- Supabase (obbligatorio in produzione) ---
# URL del progetto (stesso valore in dashboard Supabase → Settings → API).
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
#
# Chiave con privilegi completi sul server (letture, can_frames, device_commands, sessions).
# Preferire SUPABASE_SERVICE_ROLE_KEY lato server; l’anon key funziona solo se RLS consente tutte le operazioni usate dall’app.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#
# Opzionale se il client usa solo chiave pubblica (es. browser); il server usa prima SERVICE_ROLE.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
#
# Alternativa server-only (senza NEXT_PUBLIC_):
# SUPABASE_URL=https://xxxx.supabase.co

# --- API device (obbligatorio se proteggi gli endpoint ESP) ---
# Stessa stringa nell’ESP: header X-API-Key su POST /api/ingest e POST /api/can-sniffer/stream
# (e poll GET /api/device/commands con device_id).
# Se API_KEY non è impostata, il backend accetta le richieste senza header (solo sviluppo).
# API_KEY=your-shared-secret-with-esp32

# --- Analisi AI (opzionale) ---
# ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Protezione sito web (opzionale) ---
# Se impostata, richiede login su /login (le route /api/* restano accessibili per l’ESP senza cookie).
# SITE_PASSWORD=your-site-password

# --- OTA firmware (opzionale) ---
# FIRMWARE_VERSION=1.0.0
# FIRMWARE_BINARY_URL=https://your-cdn.example.com/ev-diagnostic-1.0.0.bin
# FIRMWARE_BUILD=optional-build-id

# --- VIN decoder (opzionale) ---
# VIN_DECODER_DATABASE_URL=https://...

# --- Supabase CLI (solo migrazioni locali) ---
# SUPABASE_ACCESS_TOKEN=

# =============================================================================
# Allineamento firmware ESP32 ↔ webapp
# =============================================================================
# • device_id: inviato nel JSON come "device_id" — deve coincidere con sessions.device_id
#   (nome da NVS `device_name` oppure default EV-XXYYZZ dagli ultimi byte del MAC).
# • server_url (NVS) = URL base della webapp (es. https://xxx.vercel.app), senza slash finale.
# • api_key (NVS) = stesso valore di API_KEY sopra (header X-API-Key).
# • SUPABASE_SERVICE_ROLE_KEY (o chiave con permessi su readings, can_frames, device_commands, sessions).
