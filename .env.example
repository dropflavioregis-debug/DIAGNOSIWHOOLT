# ========== REQUIRED for production (Vercel + Supabase) ==========
# Copia in web/.env.local per sviluppo; su Vercel imposta in Project Settings → Environment Variables.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ANTHROPIC_API_KEY=sk-ant-api03-...   (per analisi AI /api/analyze)
# API_KEY=your-secure-api-key-for-esp32   (stessa chiave in header X-API-Key sul dispositivo)

# ========== Site protection (optional) ==========
# SITE_PASSWORD=your-secret-password   (login su /login; vuoto = nessuna protezione)

# ========== OTA firmware (optional) ==========
# FIRMWARE_VERSION=1.0.0
# FIRMWARE_BINARY_URL=https://your-cdn.example.com/ev-diagnostic-1.0.0.bin
# FIRMWARE_BUILD=optional-build-id

# ========== VIN decoder (optional) ==========
# VIN_DECODER_DATABASE_URL=https://...   (default: CDN Corgi)

# ========== Supabase CLI (local migrations only) ==========
# SUPABASE_ACCESS_TOKEN=
